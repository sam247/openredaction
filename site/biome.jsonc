{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "root": false,
  "extends": "//",
  "files": {
    "includes": ["*", "!public"]
  },
  "linter": {
    "domains": {
      "test": "recommended",
      "next": "recommended",
      "turborepo": "recommended",
      "react": "recommended"
    },
    "rules": {
      "a11y": {
        "useButtonType": "off"
      }
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
