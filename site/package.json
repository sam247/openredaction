{
  "name": "openredaction-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run copy-openredaction && npm run docs:export && next build --turbopack",
    "copy-openredaction": "mkdir -p public/lib && cp ../packages/compat/dist/index.js public/lib/openredaction.js",
    "start": "next start",
    "lint": "biome check . --diagnostic-level=error",
    "typecheck": "tsc --noEmit --incremental",
    "docs:export": "cd docs && npm ci && npm run build && rm -rf ../public/docs && mkdir -p ../public && cp -R out ../public/docs"
  },
  "dependencies": {
    "botid": "^1.5.10",
    "clsx": "^2.1.0",
    "lucide-react": "^0.344.0",
    "next": "16.2.9",
    "nodemailer": "^9.0.1",
    "openredaction": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.4.2",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.5.18",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
