{
  "name": "openredaction-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run copy-openredaction && npm run docs:export && next build --turbopack",
    "copy-openredaction": "mkdir -p public/lib && cp ../packages/core/dist/index.js public/lib/openredaction.js",
    "start": "next start",
    "lint": "eslint .",
    "docs:export": "cd docs && npm ci && npm run build && rm -rf ../public/docs && mkdir -p ../public && cp -R out ../public/docs"
  },
  "dependencies": {
    "botid": "^1.5.10",
    "clsx": "^2.1.0",
    "lucide-react": "^0.344.0",
    "next": "16.2.9",
    "nodemailer": "^7.0.12",
    "openredaction": "workspace:*",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "^6.4.2",
    "tailwind-merge": "^2.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "^26.0.1",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.4.33",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  },
  "overrides": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  }
}
