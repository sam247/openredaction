{
  "name": "openredaction",
  "version": "0.1.1",
  "private": true,
  "description": "Production-ready PII detection and redaction library",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*",
    "site"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "tsx": "^4.22.4",
    "turbo": "^2.10.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sam247/redactit.git"
  },
  "keywords": [
    "pii",
    "redaction",
    "privacy",
    "gdpr",
    "hipaa",
    "data-protection",
    "openredaction",
    "redact",
    "sensitive-data",
    "anonymization"
  ],
  "license": "MIT"
}
