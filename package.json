{
  "name": "openredaction",
  "version": "0.1.1",
  "private": true,
  "description": "Production-ready PII detection and redaction library",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*",
    "site"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "changeset": "changeset",
    "clean": "turbo run clean",
    "prepare": "husky",
    "release": "bun run build && changeset publish",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "turbo": "2.10.2",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sam247/redactit.git"
  },
  "keywords": [
    "pii",
    "redaction",
    "privacy",
    "gdpr",
    "hipaa",
    "data-protection",
    "openredaction",
    "redact",
    "sensitive-data",
    "anonymization"
  ],
  "license": "MIT"
}
