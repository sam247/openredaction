{
  "name": "@openredaction/elysia",
  "version": "0.0.0",
  "homepage": "https://openredaction.com",
  "bugs": {
    "url": "https://github.com/sam247/openredaction/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sam247/openredaction.git",
    "directory": "packages/elysia"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "tsdown --watch",
    "lint": "biome check . --diagnostic-level=error",
    "typecheck": "tsc --noEmit --incremental",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@openredaction/core": "workspace:*"
  },
  "peerDependencies": {
    "elysia": "^1.0.0"
  },
  "devDependencies": {
    "@openredaction/core": "workspace:*",
    "@types/node": "^26.0.1",
    "elysia": "^1.3.5",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
