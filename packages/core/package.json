{
  "name": "openredaction",
  "version": "1.1.2",
  "homepage": "https://openredaction.com",
  "bugs": {
    "url": "https://github.com/sam247/openredaction/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sam247/openredaction.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.mts",
        "default": "./dist/react.mjs"
      },
      "require": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.mts",
        "default": "./dist/server.mjs"
      },
      "require": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      }
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "bench": "vitest bench --run",
    "bench:watch": "vitest bench",
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "tsdown --watch",
    "lint": "biome check . --diagnostic-level=error",
    "typecheck": "tsc --noEmit --incremental",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.6",
    "@vitest/coverage-v8": "^4.1.9",
    "express": "^5.2.1",
    "happy-dom": "^20.10.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "mammoth": "^1.6.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.0.0 || ^19.0.0",
    "tesseract.js": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "mammoth": {
      "optional": true
    },
    "pdf-parse": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "tesseract.js": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
