{
  "name": "@openredaction/react",
  "version": "1.1.2",
  "homepage": "https://openredaction.com",
  "bugs": {
    "url": "https://github.com/sam247/openredaction/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sam247/openredaction.git",
    "directory": "packages/react"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "tsdown --watch",
    "lint": "biome check . --diagnostic-level=error",
    "typecheck": "tsc --noEmit --incremental",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@openredaction/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@openredaction/core": "workspace:*",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.0.4",
    "@vitest/coverage-v8": "^4.1.9",
    "happy-dom": "^20.10.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
